{
  "name": "carbon-point",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:h5": "pnpm --filter @carbon-point/h5 dev",
    "dev:enterprise": "pnpm --filter @carbon-point/enterprise-frontend dev",
    "dev:platform": "pnpm --filter @carbon-point/platform-frontend dev",
    "dev:dashboard": "pnpm --filter @carbon-point/platform-frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test:e2e:platform": "pnpm --filter @carbon-point/platform-frontend exec playwright test --project=platform",
    "test:e2e:platform:headed": "pnpm --filter @carbon-point/platform-frontend exec playwright test --project=platform --headed",
    "test:e2e:platform:ui": "pnpm --filter @carbon-point/platform-frontend exec playwright test --project=platform --ui",
    "test:e2e": "pnpm --filter @carbon-point/platform-frontend exec playwright test",
    "test:e2e:ui": "pnpm --filter @carbon-point/platform-frontend exec playwright test --ui"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.44.0"
  }
}