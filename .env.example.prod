# ============================================================
# Carbon Point 生产环境变量示例
# ============================================================
# 复制此文件为 .env.prod 并填入真实值:
#   cp .env.example.prod .env.prod
# ============================================================

# ─────────────────────────────────────────────────────────
# 数据库
# ─────────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=<请务必修改为强密码，建议使用: openssl rand -base64 24>
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/carbon_point?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true&useServerPrepStmts=true&cachePrepStmts=true&prepStmtCacheSize=250&prepStmtCacheSqlLimit=2048

# Hikari 连接池
HIKARI_MAX_POOL=20
HIKARI_MIN_IDLE=5

# ─────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<请设置强密码，建议使用: openssl rand -base64 16>
REDIS_DATABASE=0

# ─────────────────────────────────────────────────────────
# JWT（务必修改，必须使用强随机密钥）
# ─────────────────────────────────────────────────────────
JWT_SECRET=<请生成64位随机字符串: openssl rand -base64 48>
JWT_ACCESS_EXPIRY=86400000
JWT_REFRESH_EXPIRY=604800000

# ─────────────────────────────────────────────────────────
# 安全配置
# ─────────────────────────────────────────────────────────
SECURITY_CAPTCHA_ENABLED=true
SECURITY_LOCK_ENABLED=true
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION=30

# ─────────────────────────────────────────────────────────
# Spring 配置
# ─────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=INFO

# ─────────────────────────────────────────────────────────
# Java 运行时（生产推荐 1G+ 堆内存）
# ─────────────────────────────────────────────────────────
JAVA_OPTS=-Xmx1024m -Xms512m -XX:+UseG1GC -XX:MaxRAMPercentage=75.0

# ─────────────────────────────────────────────────────────
# OSS（可选，如果使用对象存储）
# ─────────────────────────────────────────────────────────
# OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# OSS_ACCESS_KEY_ID=<your-access-key>
# OSS_ACCESS_KEY_SECRET=<your-access-secret>
# OSS_BUCKET_NAME=carbon-point
# OSS_REGION=cn-shanghai

# ─────────────────────────────────────────────────────────
# Docker Compose
# ─────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=carbon-point
