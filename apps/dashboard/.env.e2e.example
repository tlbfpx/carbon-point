# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in the values

# Base URL for Playwright tests (defaults to http://localhost:3001)
PLAYWRIGHT_BASE_URL=http://localhost:3001

# Platform Admin Credentials
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD=admin123

# Enterprise Admin (Super Admin) Credentials
ENTERPRISE_ADMIN_PHONE=13800138001
ENTERPRISE_ADMIN_PASSWORD=password123

# Enterprise Operator Credentials (limited permissions)
ENTERPRISE_OPERATOR_PHONE=13800138002
ENTERPRISE_OPERATOR_PASSWORD=password123

# Backend API URL (if different from frontend dev server)
# VITE_API_BASE_URL=http://localhost:8081/api
# VITE_PLATFORM_API_BASE_URL=http://localhost:8081/platform
