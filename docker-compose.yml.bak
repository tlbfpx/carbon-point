version: '3.8'

services:
  # ─────────────────────────────────────────────────────────
  # Spring Boot Application
  # ─────────────────────────────────────────────────────────
  app:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "9090:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=prod
      - SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3308/carbon_point?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true
      - SPRING_DATASOURCE_USERNAME=${DB_USER:-root}
      - SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD:-rootpassword}
      - SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
      - SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
      - SPRING_DATA_REDIS_HOST=host.docker.internal
      - SPRING_DATA_REDIS_PORT=6379
      - SPRING_DATA_REDIS_DATABASE=0
      - JWT_SECRET=${JWT_SECRET:-change-this-in-production}
      - JWT_ACCESS_TOKEN_EXPIRATION=86400000
      - JWT_REFRESH_TOKEN_EXPIRATION=604800000
      - SECURITY_CAPTCHA_ENABLED=true
      - SECURITY_LOCK_ENABLED=true
      - JAVA_OPTS=-Xmx512m -Xms256m
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - carbon-point_carbon-net
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
    develop:
      watch:
        - action: rebuild
          path: ./pom.xml
        - action: rebuild
          path: ./carbon-common
        - action: rebuild
          path: ./carbon-system
        - action: rebuild
          path: ./carbon-checkin
        - action: rebuild
          path: ./carbon-points
        - action: rebuild
          path: ./carbon-mall
        - action: rebuild
          path: ./carbon-report
        - action: rebuild
          path: ./carbon-app

  # ─────────────────────────────────────────────────────────
  # Nginx Reverse Proxy
  # ─────────────────────────────────────────────────────────
  nginx:
    image: nginx:alpine
    container_name: carbon-point-nginx
    ports:
      - "8081:80"
      - "8443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./dist/h5:/usr/share/nginx/html/h5:ro
      - ./dist/dashboard:/usr/share/nginx/html/dashboard:ro
    depends_on:
      - app
    networks:
      - carbon-point_carbon-net
    restart: unless-stopped

networks:
  carbon-point_carbon-net:
    external: true
