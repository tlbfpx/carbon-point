<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.carbonpoint.honor.mapper.UserBadgeMapper">

    <!-- INSERT IGNORE — 依赖 uk_user_badge (user_id, badge_id) 唯一索引 -->
    <insert id="insertIgnore">
        INSERT IGNORE INTO user_badges (user_id, badge_id, earned_at)
        VALUES (#{userId}, #{badgeId}, #{earnedAt})
    </insert>

</mapper>
